{
  "name": "bon",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "workspaces": [
    "api",
    "front",
    "pdf",
    "types"
  ],
  "scripts": {
    "format": "prettier \"api/**/*.{js,jsx,ts,tsx,json,md,css,scss,html,yml,yaml}\" \"front/**/*.{js,jsx,ts,tsx,json,md,css,scss,html,yml,yaml}\" \"pdf/**/*.{js,jsx,ts,tsx,json,md,css,scss,html,yml,yaml}\" --write",
    "format:check": "prettier \"api/**/*.{js,jsx,ts,tsx,json,md,css,scss,html,yml,yaml}\" \"front/**/*.{js,jsx,ts,tsx,json,md,css,scss,html,yml,yaml}\" \"pdf/**/*.{js,jsx,ts,tsx,json,md,css,scss,html,yml,yaml}\" --check",
    "precheck": "npm run build -w @bon/types",
    "check": "npm run format:check && npm run lint -w bon-api && npm run type-check -w bon-api && npm run test -w bon-api && npm run lint -w front && npm run type-check -w front && npm run test -w front && npm run lint -w bon-pdf && npm run type-check -w bon-pdf && npm run test -w bon-pdf"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
